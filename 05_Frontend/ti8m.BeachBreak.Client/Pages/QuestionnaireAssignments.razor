@page "/questionnaire-assignments"
@using Microsoft.AspNetCore.Components.Authorization
@using Radzen
@using Radzen.Blazor
@using ti8m.BeachBreak.Client.Models
@using ti8m.BeachBreak.Client.Services
@using ti8m.BeachBreak.Client.Components.Dialogs
@using ti8m.BeachBreak.Client.Components.Shared
@using ti8m.BeachBreak.Client.Layout
@inject IQuestionnaireAssignmentService AssignmentService
@inject IQuestionnaireTemplateService TemplateService
@inject ICategoryApiService CategoryApiService
@inject DialogService DialogService
@inject NavigationManager NavigationManager
@inherits CategoryOptimizedTranslatableComponent

<PageTitle>@T("pages.questionnaire-assignments")</PageTitle>

<link href="css/assignment-dialogs.css" rel="stylesheet" />

<AuthorizeView Policy="HR">
    <Authorized>
        <PageLayout Type="LayoutType.Standard"
                   Title="@T("pages.questionnaire-assignments")"
                   Description="@T("pages.questionnaire-assignments-description")">
            <HeaderActions>
                <RadzenButton Text="@T("buttons.create-new")"
                             ButtonStyle="ButtonStyle.Primary"
                             Icon="add"
                             Size="ButtonSize.Medium"
                             Click="@NavigateToCreate" />
            </HeaderActions>
            <ChildContent>
                <div>
                    <!-- Filters -->
                    <div class="py-3 border-bottom">
                        <RadzenRow Gap="1rem" AlignItems="AlignItems.End">
                            <RadzenColumn Size="12" SizeMD="3">
                                <RadzenLabel Text="@T("labels.filter-by-status")" />
                                <RadzenDropDown @bind-Value="@statusFilter"
                                                Data="@statusOptions"
                                                TextProperty="Text"
                                                ValueProperty="Value"
                                                AllowClear="true"
                                                Change="@FilterAssignments"
                                                Class="w-100" />
                            </RadzenColumn>
                            <RadzenColumn Size="12" SizeMD="9">
                                <RadzenLabel Text="@T("labels.search")" />
                                <RadzenTextBox @bind-Value="@searchText"
                                               Placeholder="@T("placeholders.search-employee-name-email")"
                                               @oninput="@((e) => { searchText = e.Value?.ToString() ?? ""; FilterAssignments(); })"
                                               Class="w-100" />
                            </RadzenColumn>
                        </RadzenRow>
                        <RadzenRow Gap="1rem" AlignItems="AlignItems.End" Class="mt-2">
                            <RadzenColumn Size="12" SizeMD="3">
                                <RadzenLabel Text="@T("labels.filter-by-organisation")" />
                                <RadzenDropDown @bind-Value="@organisationFilter"
                                                Data="@organisationOptions"
                                                AllowClear="true"
                                                Multiple="true"
                                                Placeholder="@T("placeholders.all-organisations")"
                                                Change="@FilterAssignments"
                                                Class="w-100" />
                            </RadzenColumn>
                            <RadzenColumn Size="12" SizeMD="3">
                                <RadzenLabel Text="@T("labels.filter-by-role")" />
                                <RadzenDropDown @bind-Value="@roleFilter"
                                                Data="@roleOptions"
                                                AllowClear="true"
                                                Multiple="true"
                                                Placeholder="@T("placeholders.all-roles")"
                                                Change="@FilterAssignments"
                                                Class="w-100" />
                            </RadzenColumn>
                            <RadzenColumn Size="12" SizeMD="6" Class="d-flex align-items-end">
                                <AsyncButton Text="@T("buttons.refresh")"
                                             ProcessingText="@T("labels.loading")"
                                             ButtonStyle="ButtonStyle.Light"
                                             Icon="refresh"
                                             Click="@(() => LoadAssignments())" />
                            </RadzenColumn>
                        </RadzenRow>
                    </div>

                    <!-- Assignments Grid -->
                    <RadzenDataGrid @ref="assignmentsGrid"
                                    Data="@filteredAssignments"
                                    AllowFiltering="true"
                                    AllowColumnResize="true"
                                    AllowAlternatingRows="true"
                                    FilterMode="FilterMode.Advanced"
                                    AllowSorting="true"
                                    PageSize="20"
                                    AllowPaging="true"
                                    PagerHorizontalAlign="HorizontalAlign.Left"
                                    ShowPagingSummary="true"
                                    LoadData="@LoadAssignments">
                        <Columns>
                            <RadzenDataGridColumn Property="@nameof(QuestionnaireAssignment.EmployeeName)" Title="@T("columns.employee")" Frozen="true" Width="200px">
                                <Template Context="assignment">
                                    <div>
                                        <RadzenText TextStyle="TextStyle.Body2" Class="fw-bold">@assignment.EmployeeName</RadzenText>
                                        @if (!string.IsNullOrEmpty(assignment.EmployeeRole))
                                        {
                                            <div><RadzenText TextStyle="TextStyle.Caption" Class="text-muted">@assignment.EmployeeRole</RadzenText></div>
                                        }
                                        @if (!string.IsNullOrEmpty(assignment.EmployeeOrganisationName))
                                        {
                                            <div><RadzenText TextStyle="TextStyle.Caption" Class="text-muted">@assignment.EmployeeOrganisationName</RadzenText></div>
                                        }
                                    </div>
                                </Template>
                            </RadzenDataGridColumn>

                            <RadzenDataGridColumn Property="TemplateName" Title="@T("columns.questionnaire")" Width="250px">
                                <Template Context="assignment">
                                    <div>
                                        <RadzenText TextStyle="TextStyle.Body2" Class="fw-bold">@GetTemplateName(assignment.TemplateId)</RadzenText>
                                        <RadzenText TextStyle="TextStyle.Caption" Class="text-muted">@GetTemplateCategoryName(assignment.TemplateId)</RadzenText>
                                    </div>
                                </Template>
                            </RadzenDataGridColumn>

                            <RadzenDataGridColumn Property="@nameof(QuestionnaireAssignment.WorkflowState)" Title="@T("columns.status")" Width="180px">
                                <Template Context="assignment">
                                    <RadzenBadge Text="@T(WorkflowStateHelper.GetStateDisplayName(assignment.WorkflowState))"
                                                 BadgeStyle="BadgeStyle.Light"
                                                 Style="@($"font-size: 0.75rem; background-color: {WorkflowStateHelper.GetStateColor(assignment.WorkflowState)}; color: white;")" />
                                </Template>
                            </RadzenDataGridColumn>

                            <RadzenDataGridColumn Property="@nameof(QuestionnaireAssignment.AssignedDate)" Title="@T("columns.assigned")" Width="120px" FormatString="{0:dd/MM/yyyy}" />

                            <RadzenDataGridColumn Property="@nameof(QuestionnaireAssignment.DueDate)" Title="@T("columns.due-date")" Width="120px">
                                <Template Context="assignment">
                                    @if (assignment.DueDate.HasValue)
                                    {
                                        var isOverdue = assignment.DueDate < DateTime.Now && assignment.WorkflowState != WorkflowState.Finalized;
                                        <RadzenText TextStyle="TextStyle.Body2"
                                                    Class="@(isOverdue ? "text-danger fw-bold" : "")">
                                            @assignment.DueDate.Value.ToString("dd/MM/yyyy")
                                            @if (isOverdue)
                                            {
                                                <RadzenIcon Icon="warning" Class="ms-1" />
                                            }
                                        </RadzenText>
                                    }
                                    else
                                    {
                                        <span class="text-muted">@T("labels.no-due-date")</span>
                                    }
                                </Template>
                            </RadzenDataGridColumn>

                            <RadzenDataGridColumn Property="@nameof(QuestionnaireAssignment.FinalizedDate)" Title="@T("columns.completed")" Width="120px">
                                <Template Context="assignment">
                                    @if (assignment.FinalizedDate.HasValue)
                                    {
                                        <RadzenText TextStyle="TextStyle.Body2">@assignment.FinalizedDate.Value.ToString("dd/MM/yyyy")</RadzenText>
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </Template>
                            </RadzenDataGridColumn>

                            <RadzenDataGridColumn Property="@nameof(QuestionnaireAssignment.AssignedBy)" Title="@T("columns.assigned-by")" Width="150px" />

                            <RadzenDataGridColumn Filterable="false" Sortable="false" Width="160px" TextAlign="TextAlign.Center" Title="@T("columns.actions")">
                                <Template Context="assignment">
                                    <AssignmentActionButtons Assignment="@assignment"
                                                             OnActionClick="@HandleAssignmentActionClick"
                                                             ShowEditAction="true"
                                                             ShowReminderAction="true"
                                                             ShowCancelAction="true" />
                                </Template>
                            </RadzenDataGridColumn>
                        </Columns>
                    </RadzenDataGrid>
                </div>
            </ChildContent>
        </PageLayout>
    </Authorized>
    <NotAuthorized>
        <AccessDeniedComponent RequiredRole="HR" PageName="@T("pages.questionnaire-assignments")" />
    </NotAuthorized>
</AuthorizeView>

@code {

    private List<QuestionnaireTemplate> allQuestionnaires = new();
    private List<QuestionnaireAssignment> assignments = new();
    private List<QuestionnaireAssignment> filteredAssignments = new();
    private List<Category> categories = new();

    private RadzenDataGrid<QuestionnaireAssignment> assignmentsGrid = default!;
    private bool isProcessingAction = false;

    private string searchText = "";
    private WorkflowState? statusFilter;
    private IEnumerable<string> organisationFilter = new List<string>();
    private IEnumerable<string> roleFilter = new List<string>();
    private List<StatusOption> statusOptions = new();
    private List<string> organisationOptions = new();
    private List<string> roleOptions = new();

    protected override string[] GetRequiredTranslationCategories()
    {
        return new[]
        {
            TranslationCategories.Pages,
            TranslationCategories.Buttons,
            TranslationCategories.Columns,
            TranslationCategories.Filters,
            TranslationCategories.Labels,
            TranslationCategories.Placeholders,
            TranslationCategories.Messages,
            TranslationCategories.Notifications,
            TranslationCategories.Dialogs,
            TranslationCategories.WorkflowStates,
            TranslationCategories.Actions
        };
    }

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        InitializeStatusOptions();
        await LoadInitialData();
    }

    private void InitializeStatusOptions()
    {
        statusOptions = new List<StatusOption>
        {
            new(T("workflow-states.all"), null),
            new(T("workflow-states.assigned"), WorkflowState.Assigned),
            new(T("workflow-states.employee-in-progress"), WorkflowState.EmployeeInProgress),
            new(T("workflow-states.manager-in-progress"), WorkflowState.ManagerInProgress),
            new(T("workflow-states.both-in-progress"), WorkflowState.BothInProgress),
            new(T("workflow-states.employee-submitted"), WorkflowState.EmployeeSubmitted),
            new(T("workflow-states.manager-submitted"), WorkflowState.ManagerSubmitted),
            new(T("workflow-states.both-submitted"), WorkflowState.BothSubmitted),
            new(T("workflow-states.in-review"), WorkflowState.InReview),
            new(T("workflow-states.employee-review-confirmed"), WorkflowState.EmployeeReviewConfirmed),
            new(T("workflow-states.manager-review-confirmed"), WorkflowState.ReviewFinished),
            new(T("workflow-states.finalized"), WorkflowState.Finalized)
        };
    }

    private async Task LoadInitialData()
    {
        var questionnairesTask = TemplateService.GetAllTemplatesAsync();
        var assignmentsTask = AssignmentService.GetAllAssignmentsAsync();
        var categoriesTask = CategoryApiService.GetAllCategoriesAsync();

        await Task.WhenAll(questionnairesTask, assignmentsTask, categoriesTask);

        allQuestionnaires = await questionnairesTask;
        assignments = await assignmentsTask;
        categories = await categoriesTask;

        RebuildFilterOptions();
        FilterAssignments();
    }

    private async Task LoadAssignments(LoadDataArgs? args = null)
    {
        try
        {
            assignments = await AssignmentService.GetAllAssignmentsAsync();
            RebuildFilterOptions();
            FilterAssignments();
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, T("notifications.error"), T("notifications.failed-load-assignments"));
            Console.WriteLine($"Error loading assignments: {ex.Message}");
        }
    }

    private void RebuildFilterOptions()
    {
        organisationOptions = assignments
            .Where(a => !string.IsNullOrWhiteSpace(a.EmployeeOrganisationName))
            .Select(a => a.EmployeeOrganisationName)
            .Distinct()
            .OrderBy(o => o)
            .ToList();

        roleOptions = assignments
            .Where(a => !string.IsNullOrWhiteSpace(a.EmployeeRole))
            .Select(a => a.EmployeeRole)
            .Distinct()
            .OrderBy(r => r)
            .ToList();
    }

    private void FilterAssignments()
    {
        var term = searchText?.Trim() ?? "";
        var orgs = organisationFilter?.ToList() ?? new List<string>();
        var roles = roleFilter?.ToList() ?? new List<string>();

        filteredAssignments = assignments.Where(a =>
            (statusFilter == null || a.WorkflowState == statusFilter) &&
            (!orgs.Any() || orgs.Contains(a.EmployeeOrganisationName)) &&
            (!roles.Any() || roles.Contains(a.EmployeeRole)) &&
            (string.IsNullOrWhiteSpace(term) ||
             a.EmployeeName.Contains(term, StringComparison.OrdinalIgnoreCase) ||
             a.EmployeeEmail.Contains(term, StringComparison.OrdinalIgnoreCase) ||
             (!string.IsNullOrEmpty(a.EmployeeRole) && a.EmployeeRole.Contains(term, StringComparison.OrdinalIgnoreCase)) ||
             (!string.IsNullOrEmpty(a.EmployeeOrganisationName) && a.EmployeeOrganisationName.Contains(term, StringComparison.OrdinalIgnoreCase)))
        ).ToList();

        StateHasChanged();
    }

    private string GetTemplateName(Guid templateId)
    {
        return allQuestionnaires.FirstOrDefault(q => q.Id == templateId)?.GetLocalizedNameWithFallback(CurrentLanguage) ?? T("labels.unknown-questionnaire");
    }

    private string GetTemplateCategoryName(Guid templateId)
    {
        var template = allQuestionnaires.FirstOrDefault(q => q.Id == templateId);
        if (template == null) return "";
        return categories.FirstOrDefault(c => c.Id == template.CategoryId)?.NameEn ?? T("labels.uncategorized");
    }

    private void NavigateToCreate()
    {
        NavigationManager.NavigateTo("/questionnaire-assignments/create");
    }

    private async Task HandleAssignmentActionClick(AssignmentActionButtons.AssignmentActionEventArgs eventArgs)
    {
        if (isProcessingAction) return;

        switch (eventArgs.Action)
        {
            case "edit":
                await HandleEditAction(eventArgs.Assignment);
                break;
            case "remind":
                await HandleReminderAction(eventArgs.Assignment);
                break;
            case "cancel":
                await HandleCancelAction(eventArgs.Assignment);
                break;
        }
    }

    private async Task HandleEditAction(QuestionnaireAssignment assignment)
    {
        try
        {
            var result = await DialogService.OpenAsync<EditAssignmentDialog>($"{T("dialogs.edit-assignment")} - {assignment.EmployeeName}",
                new Dictionary<string, object>
                {
                    { "Assignment", assignment }
                },
                new DialogOptions
                {
                    Width = "600px",
                    Height = "auto",
                    Resizable = true,
                    Draggable = true,
                    CloseDialogOnOverlayClick = true,
                    ShowClose = true
                });

            if (result is EditAssignmentDialog.EditAssignmentResult editResult)
            {
                var success = await AssignmentService.UpdateAssignmentPropertiesAsync(
                    assignment.Id,
                    editResult.NewDueDate,
                    editResult.NewNotes);

                if (success)
                {
                    NotificationService.Notify(NotificationSeverity.Success,
                        T("notifications.assignment-updated"),
                        $"{T("notifications.assignment-updated-successfully")} {assignment.EmployeeName}");
                    await LoadAssignments();
                }
                else
                {
                    NotificationService.Notify(NotificationSeverity.Error,
                        T("notifications.error"),
                        T("notifications.failed-update-assignment"));
                }
            }
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, T("notifications.error"),
                $"{T("notifications.failed-open-edit")}: {ex.Message}");
        }
    }

    private async Task HandleReminderAction(QuestionnaireAssignment assignment)
    {
        isProcessingAction = true;
        StateHasChanged();

        try
        {
            var confirmed = await DialogService.Confirm(
                $"{T("messages.send-reminder-confirmation")} {assignment.EmployeeName}?",
                T("dialogs.send-reminder"),
                new ConfirmOptions { OkButtonText = T("buttons.send"), CancelButtonText = T("buttons.cancel") });

            if (confirmed == true)
            {
                NotificationService.Notify(NotificationSeverity.Success,
                    T("notifications.reminder-sent"),
                    $"{T("notifications.reminder-sent-success")} {assignment.EmployeeName}",
                    duration: 5000);
            }
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, T("notifications.error"),
                $"{T("notifications.failed-send-reminder")}: {ex.Message}");
        }
        finally
        {
            isProcessingAction = false;
            StateHasChanged();
        }
    }

    private async Task HandleCancelAction(QuestionnaireAssignment assignment)
    {
        isProcessingAction = true;
        StateHasChanged();

        try
        {
            var confirmed = await DialogService.Confirm(
                $"{T("messages.cancel-assignment-confirmation")} {assignment.EmployeeName}?",
                T("dialogs.cancel-assignment"),
                new ConfirmOptions
                {
                    OkButtonText = T("buttons.cancel-assignment"),
                    CancelButtonText = T("buttons.keep-assignment")
                });

            if (confirmed == true)
            {
                var success = await AssignmentService.WithdrawAssignmentAsync(
                    assignment.Id,
                    "Assignment cancelled by HR user via management interface");

                if (success)
                {
                    NotificationService.Notify(NotificationSeverity.Success,
                        T("notifications.assignment-cancelled"),
                        $"{T("notifications.assignment-cancelled-successfully")} {assignment.EmployeeName}");
                    await LoadAssignments();
                }
                else
                {
                    NotificationService.Notify(NotificationSeverity.Error,
                        T("notifications.error"),
                        T("notifications.failed-cancel-assignment"));
                }
            }
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, T("notifications.error"),
                $"{T("notifications.failed-cancel-assignment")}: {ex.Message}");
        }
        finally
        {
            isProcessingAction = false;
            StateHasChanged();
        }
    }

    public class StatusOption
    {
        public StatusOption(string text, WorkflowState? value)
        {
            Text = text;
            Value = value;
        }
        public string Text { get; set; }
        public WorkflowState? Value { get; set; }
    }

}