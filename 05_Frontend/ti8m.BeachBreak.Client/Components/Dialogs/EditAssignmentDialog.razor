@using Radzen
@using Radzen.Blazor
@using ti8m.BeachBreak.Client.Components.Shared
@using ti8m.BeachBreak.Client.Models
@inject DialogService DialogService
@inherits CategoryOptimizedTranslatableComponent

<div class="edit-assignment-form">

    <div class="edit-context-strip">
        <RadzenIcon Icon="assignment" Style="color: var(--rz-primary, #667eea); font-size: 1.25rem; flex-shrink: 0;" />
        <span class="edit-context-questionnaire">@Assignment?.TemplateName</span>
        <RadzenBadge Text="@T(WorkflowStateHelper.GetStateDisplayName(Assignment!.WorkflowState))"
                     BadgeStyle="BadgeStyle.Light"
                     Style="@($"font-size: 0.75rem; background-color: {WorkflowStateHelper.GetStateColor(Assignment.WorkflowState)}; color: white; flex-shrink: 0;")" />
    </div>

    <div class="edit-form-field">
        <label class="edit-form-label">@T("labels.due-date")</label>
        <RadzenDatePicker @bind-Value="@newDueDate"
                         Min="@DateTime.Today"
                         DateFormat="dd/MM/yyyy"
                         Style="width: 100%;"
                         ShowCalendarWeek="true"
                         Placeholder="@T("placeholders.select-due-date")" />
    </div>

    <div class="edit-form-field">
        <div class="d-flex justify-content-between align-items-baseline mb-1">
            <label class="edit-form-label mb-0">@T("labels.notes-optional")</label>
            <small class="text-muted">@(newNotes?.Length ?? 0) / 1000</small>
        </div>
        <RadzenTextArea @bind-Value="@newNotes"
                       Placeholder="@T("placeholders.assignment-notes")"
                       Rows="4"
                       Style="width: 100%;"
                       MaxLength="1000" />
    </div>

    <div class="edit-form-actions">
        <AsyncButton Text="@T("buttons.cancel")"
                    ButtonStyle="ButtonStyle.Light"
                    Click="@Cancel"
                    Size="ButtonSize.Medium" />
        <AsyncButton Text="@T("buttons.save-changes")"
                    ProcessingText="@T("buttons.saving")"
                    ButtonStyle="ButtonStyle.Primary"
                    Icon="save"
                    Click="@SaveChanges"
                    Size="ButtonSize.Medium"
                    Disabled="@(!HasChanges())" />
    </div>

</div>

@code {
    [Parameter] public QuestionnaireAssignment? Assignment { get; set; }

    protected override string[] GetRequiredTranslationCategories()
    {
        return new[]
        {
            TranslationCategories.Labels,
            TranslationCategories.Buttons,
            TranslationCategories.Placeholders,
            TranslationCategories.WorkflowStates
        };
    }

    private DateTime? newDueDate;
    private string? newNotes;

    protected override void OnInitialized()
    {
        base.OnInitialized();

        if (Assignment != null)
        {
            newDueDate = Assignment.DueDate;
            newNotes = Assignment.Notes;
        }
    }

    private void Cancel()
    {
        DialogService.Close();
    }

    private void SaveChanges()
    {
        if (!HasChanges())
        {
            Cancel();
            return;
        }

        DialogService.Close(new EditAssignmentResult
        {
            NewDueDate = newDueDate,
            NewNotes = newNotes?.Trim()
        });
    }

    private bool HasChanges()
    {
        if (Assignment == null) return false;

        if (newDueDate != Assignment.DueDate) return true;

        var currentNotes = Assignment.Notes?.Trim() ?? string.Empty;
        var updatedNotes = newNotes?.Trim() ?? string.Empty;
        return currentNotes != updatedNotes;
    }

    public class EditAssignmentResult
    {
        public DateTime? NewDueDate { get; set; }
        public string? NewNotes { get; set; }
    }
}
