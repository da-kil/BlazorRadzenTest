@using Radzen
@using Radzen.Blazor
@using ti8m.BeachBreak.Client.Components.Shared
@using ti8m.BeachBreak.Client.Models
@inject DialogService DialogService
@inherits CategoryOptimizedTranslatableComponent

<div class="dialog-container">
    <div class="dialog-review-info">
        <div class="text-center">
            <RadzenIcon Icon="edit" Class="dialog-header-icon" />
            <RadzenText TextStyle="TextStyle.H5" Class="mb-2">
                @T("dialogs.edit-assignment")
            </RadzenText>
            <RadzenText TextStyle="TextStyle.Body2">
                @T("messages.edit-assignment-description")
            </RadzenText>
        </div>
    </div>

    <div class="info-section">
        <div class="icon-box">
            <RadzenIcon Icon="assignment" Style="color: #2196F3;" />
            <RadzenText TextStyle="TextStyle.Subtitle2" Class="fw-bold mb-0">
                @T("labels.assignment-information")
            </RadzenText>
        </div>
        <RadzenText TextStyle="TextStyle.Body2" Class="text-muted">
            <strong>@T("labels.employee"):</strong> @Assignment?.EmployeeName (@Assignment?.EmployeeEmail)
        </RadzenText>
        <RadzenText TextStyle="TextStyle.Body2" Class="text-muted">
            <strong>@T("labels.questionnaire"):</strong> @Assignment?.TemplateName
        </RadzenText>
        <RadzenText TextStyle="TextStyle.Body2" Class="text-muted">
            <strong>@T("labels.current-state"):</strong> @(Assignment?.WorkflowState != null ? T(WorkflowStateHelper.GetStateDisplayName(Assignment.WorkflowState)) : "Unknown")
        </RadzenText>
    </div>

    <div class="dialog-content-section">
        <RadzenText TextStyle="TextStyle.Subtitle2" Class="fw-bold mb-2">
            @T("fields.due-date")
        </RadzenText>
        <RadzenText TextStyle="TextStyle.Body2" Class="text-muted mb-2">
            @T("messages.due-date-optional-explanation")
        </RadzenText>
        <RadzenDatePicker @bind-Value="@newDueDate"
                         Min="@DateTime.Today"
                         DateFormat="dd/MM/yyyy"
                         Style="width: 100%; margin-bottom: 1rem;"
                         ShowCalendarWeek="true"
                         Placeholder="@T("placeholders.select-due-date")" />
    </div>

    <div class="dialog-content-section">
        <RadzenText TextStyle="TextStyle.Subtitle2" Class="fw-bold mb-2">
            @T("fields.assignment-notes")
        </RadzenText>
        <RadzenText TextStyle="TextStyle.Body2" Class="text-muted mb-2">
            @T("messages.assignment-notes-explanation")
        </RadzenText>
        <RadzenTextArea @bind-Value="@newNotes"
                       Placeholder="@T("placeholders.assignment-notes")"
                       Rows="4"
                       Style="width: 100%;"
                       MaxLength="1000" />
        <RadzenText TextStyle="TextStyle.Caption" Class="text-muted" Style="margin-top: 0.5rem;">
            @(newNotes?.Length ?? 0) / 1000 @T("forms.characters")
        </RadzenText>
    </div>

    <div class="info-section" style="background: rgba(255, 193, 7, 0.05); border-left: 4px solid #FFC107;">
        <div class="icon-box">
            <RadzenIcon Icon="info" Style="color: #FFC107;" />
            <RadzenText TextStyle="TextStyle.Subtitle2" Class="fw-bold mb-0">
                @T("labels.important-note")
            </RadzenText>
        </div>
        <RadzenText TextStyle="TextStyle.Body2" Class="text-muted">
            @T("messages.assignment-edit-warning")
        </RadzenText>
        @if (newDueDate.HasValue)
        {
            <RadzenText TextStyle="TextStyle.Body2" Class="text-muted mt-2">
                <strong>@T("labels.new-due-date"):</strong> @newDueDate.Value.ToString("dd/MM/yyyy")
            </RadzenText>
        }
    </div>

    <div class="dialog-actions">
        <AsyncButton Text="@T("buttons.cancel")"
                    ButtonStyle="ButtonStyle.Light"
                    Click="@Cancel"
                    Size="ButtonSize.Medium" />
        <AsyncButton Text="@T("buttons.save-changes")"
                    ProcessingText="@T("buttons.saving-changes")"
                    ButtonStyle="ButtonStyle.Primary"
                    Icon="save"
                    Click="@SaveChanges"
                    Size="ButtonSize.Medium"
                    Disabled="@(!HasChanges())" />
    </div>
</div>

@code {
    [Parameter] public QuestionnaireAssignment? Assignment { get; set; }

    protected override string[] GetRequiredTranslationCategories()
    {
        return new[]
        {
            TranslationCategories.Dialogs,
            TranslationCategories.Messages,
            TranslationCategories.Labels,
            TranslationCategories.Buttons,
            TranslationCategories.Placeholders
        };
    }

    private DateTime? newDueDate;
    private string? newNotes;

    protected override void OnInitialized()
    {
        base.OnInitialized();

        // Pre-populate with current values
        if (Assignment != null)
        {
            newDueDate = Assignment.DueDate;
            newNotes = Assignment.Notes;
        }
    }

    private void Cancel()
    {
        DialogService.Close();
    }

    private void SaveChanges()
    {
        if (!HasChanges())
        {
            Cancel();
            return;
        }

        // Return the updated values
        var result = new EditAssignmentResult
        {
            NewDueDate = newDueDate,
            NewNotes = newNotes?.Trim()
        };

        DialogService.Close(result);
    }

    private bool HasChanges()
    {
        if (Assignment == null) return false;

        // Check if due date changed
        if (newDueDate != Assignment.DueDate) return true;

        // Check if notes changed (handle null/empty as equivalent)
        var currentNotes = Assignment.Notes?.Trim() ?? string.Empty;
        var updatedNotes = newNotes?.Trim() ?? string.Empty;
        return currentNotes != updatedNotes;
    }

    public class EditAssignmentResult
    {
        public DateTime? NewDueDate { get; set; }
        public string? NewNotes { get; set; }
    }
}